max.llm.enabled=true

# ----- OpenAI-compatible HTTP API (required) -----
# Set MAX_LLM_API_URL and MAX_LLM_API_KEY in your env, then run: envsubst < test/max.config.llm.example > /tmp/max.config && adb push /tmp/max.config /sdcard/max.config
max.llm.apiUrl=${MAX_LLM_API_URL}
max.llm.apiKey=${MAX_LLM_API_KEY}
max.llm.model=qwen3-vl-flash

# ----- 可选：请求参数 -----
# 单次回复最大 token 数，默认 256
max.llm.maxTokens=32648
# 请求超时毫秒，默认 15000
max.llm.timeoutMs=20000

max.randomPickFromStringList = false
max.takeScreenshot = false
max.takeScreenshotForEveryStep = false
max.saveGUITreeToXmlEveryStep = true
max.execSchema = true
max.execSchemaEveryStartup  = true
max.grantAllPermission = true
# max.staticStateAbstraction = true

# ----- only when true are LLM calls made -----
# max.llm.knowledge=true       # same-function grouping (knowledge_org)
# max.llm.contextAwareInput=true   # content-aware input for editable widgets (content_aware_input)